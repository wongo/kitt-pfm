---
import '../styles/global.css'

interface Props {
  title: string
}

const { title } = Astro.props
const { pathname } = Astro.url

const navItems = [
  { href: '/', label: 'DASHBOARD', icon: '◈' },
  { href: '/transactions', label: 'TRANSACTIONS', icon: '◇' },
  { href: '/assets', label: 'ASSETS', icon: '◆' },
  { href: '/budget', label: 'BUDGET', icon: '◉' },
  { href: '/fixed-costs', label: 'FIXED COSTS', icon: '◎' },
  { href: '/analysis', label: 'ANALYSIS', icon: '◐' },
]

function isActive(href: string) {
  if (href === '/') return pathname === '/'
  return pathname.startsWith(href)
}
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | KITT PFM</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <!-- KITT Scanner Line -->
    <div class="scanner-line"></div>

    <!-- Top Header Bar -->
    <header class="fixed top-0 left-0 right-0 z-50 border-b border-[#2a2a2a]" style="background:#0a0a0aee;">
      <div class="flex items-center justify-between px-6 py-3">
        <!-- Logo -->
        <div class="flex items-center gap-4">
          <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full bg-[#ff2d2d] animate-pulse"></div>
            <span class="text-[#ff2d2d] font-bold tracking-widest text-lg kitt-glow">KITT</span>
          </div>
          <span class="text-[#888]">|</span>
          <span class="text-[#888] text-sm">PFM SYSTEM</span>
        </div>
        <!-- Right: Status -->
        <div class="flex items-center gap-4">
          <div class="text-[#888] text-xs">
            <span class="text-[#00ff88]">●</span> SYSTEM ONLINE
          </div>
          <div class="text-[#888] text-xs">
            {new Date().toLocaleDateString('ja-JP', { year: 'numeric', month: '2-digit', day: '2-digit' })}
          </div>
        </div>
      </div>
    </header>

    <!-- Sidebar + Main Layout -->
    <div class="flex pt-[52px]">
      <!-- Sidebar Navigation (MoneyForward style) -->
      <aside class="fixed left-0 top-[52px] bottom-0 w-52 border-r border-[#2a2a2a] bg-[#0a0a0a] overflow-y-auto">
        <nav class="py-4">
          <div class="px-4 mb-4">
            <div class="text-[#888] text-xs tracking-widest">MENU</div>
          </div>
          {navItems.map((item) => (
            <a
              href={item.href}
              class={`flex items-center gap-3 px-4 py-3 text-sm transition-colors ${
                isActive(item.href)
                  ? 'bg-[#ff2d2d10] border-r-2 border-[#ff2d2d] text-[#ff2d2d]'
                  : 'text-[#888] hover:bg-[#1a1a1a] hover:text-[#e0e0e0]'
              }`}
            >
              <span class={`text-lg ${isActive(item.href) ? 'text-[#ff2d2d]' : 'text-[#555]'}`}>{item.icon}</span>
              <span class="font-medium tracking-wide">{item.label}</span>
            </a>
          ))}
        </nav>

        <!-- Bottom: KITT status -->
        <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-[#2a2a2a]">
          <div class="flex items-center gap-2 mb-2">
            <div class="w-2 h-2 rounded-full bg-[#ff2d2d] animate-pulse"></div>
            <span class="text-[#888] text-xs">KITT v1.0</span>
          </div>
          <div class="text-[#555] text-xs">Knight Industries</div>
        </div>
      </aside>

      <!-- Main Content Area -->
      <main class="flex-1 ml-52 min-h-[calc(100vh-52px)]">
        <div class="p-8 max-w-5xl mx-auto">
          <slot />
        </div>
      </main>
    </div>
  </body>
</html>
